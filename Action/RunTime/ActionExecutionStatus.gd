extends RefCounted
class_name ActionExecutionStatus

enum Id {

	#--------------------------------------------------------------------------
	# Continue execution next frame.
	#--------------------------------------------------------------------------

	RUNNING,

	#--------------------------------------------------------------------------
	# Waiting for an external event.
	# Examples:
	# Animation
	# Navigation
	# Network
	# Timeline
	#--------------------------------------------------------------------------

	WAITING,

	#--------------------------------------------------------------------------
	# Execution completed successfully.
	#--------------------------------------------------------------------------

	COMPLETED,

	#--------------------------------------------------------------------------
	# Execution failed.
	#--------------------------------------------------------------------------

	FAILED
}
